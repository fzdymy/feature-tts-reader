                    HStack(spacing: 4) {
                        Image(systemName: "chevron.left")
                            .font(.title3)
                        Text("退出朗读")
                            .font(.subheadline)
                    }
                    .foregroundColor(textColor.opacity(0.7))
                }
            } else {
                HStack(spacing: 8) {
                    Button(action: {
                        ReaderStore.saveLastChapterIndex(currentChapterIndex, for: bookID)
                        store.saveState()
                        dismiss()
                    }) {
                        Image(systemName: "xmark.circle.fill")
