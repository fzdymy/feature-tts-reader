            Spacer()

            if isAudioMode {
                Button(action: { showCharacterList.toggle() }) {
                    HStack(spacing: 4) {
                        Image(systemName: showCharacterList ? "person.2.fill" : "person.2")
                            .font(.title3)
                        if !store.characters.isEmpty {
                            Text("\(store.characters.count)")
                                .font(.caption2)
                        }
                    }
